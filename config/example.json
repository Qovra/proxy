{
    "listen": ":5520",
    "session_timeout": 7200,
    "metrics_listen": ":9090",
    "handlers": [
        {
            "type": "ip-ratelimit",
            "config": {
                "max_conns_per_ip": 10,
                "refill_per_sec": 1
            }
        },
        {
            "type": "sni-router",
            "config": {
                "routes": {
                    "play.example.com": "127.0.0.1:5521",
                    "lobby.example.com": [
                        "127.0.0.1:5522",
                        "127.0.0.1:5523"
                    ]
                }
            }
        },
        {
            "type": "forwarder"
        }
    ]
}