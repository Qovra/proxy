{
    "listen": ":5521",
    "session_timeout": 7200,
    "metrics_listen": ":9090",
    "handlers": [
        {
            "type": "ip-ratelimit",
            "config": {
                "max_conns_per_ip": 10,
                "refill_per_sec": 1
            }
        },
        {
            "type": "ip-connlimit",
            "config": {
                "max_conns_per_ip": 5,
                "burst": 3
            }
        },
        {
            "type": "sni-router",
            "config": {
                "routes": {
                    "localhost": ["127.0.0.1:5520", "127.0.0.1:5522"]
                }
            }
        },
        {
            "type": "forwarder"
        }
    ]
}